# ==============================================
# VARIABLES DE ENTORNO - HappyCheese
# ==============================================
# Copia este archivo a .env.local para desarrollo local
# En producción (Vercel), configura estas variables en el dashboard
# ==============================================

# ---------------------------------------------
# SUPABASE
# ---------------------------------------------
# Obtén estos valores en: https://supabase.com → Tu Proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ---------------------------------------------
# STRIPE - DESARROLLO (TEST)
# ---------------------------------------------
# Para desarrollo local, usa claves de TEST:
# Obtén en: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_tu_publishable_key
STRIPE_SECRET_KEY=sk_test_tu_secret_key
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret

# Para desarrollo local, obtén el webhook secret con:
# stripe listen --forward-to localhost:3000/api/webhooks/stripe

# ---------------------------------------------
# STRIPE - PRODUCCIÓN (LIVE)
# ---------------------------------------------
# ⚠️ Para producción en Vercel, usa claves de PRODUCCIÓN:
# Obtén en: https://dashboard.stripe.com/apikeys (modo en vivo)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_tu_publishable_key
# STRIPE_SECRET_KEY=sk_live_tu_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret (del webhook en dashboard)

# ---------------------------------------------
# APP CONFIGURATION
# ---------------------------------------------
# Desarrollo local:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Producción (actualiza en Vercel):
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# ---------------------------------------------
# EMAIL (RESEND)
# ---------------------------------------------
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_tu_api_key

# Emails de las tiendas (donde llegan las notificaciones)
STORE_EMAIL_CENTRAL=central@happycheese.com
STORE_EMAIL_NORTE=norte@happycheese.com

# ---------------------------------------------
# NOTAS IMPORTANTES
# ---------------------------------------------
# 1. NUNCA hagas commit de archivos .env.local (verificar .gitignore)
# 2. En desarrollo, usa claves de TEST de Stripe
# 3. En producción, usa claves de LIVE de Stripe
# 4. El webhook secret es diferente entre desarrollo y producción
# 5. Configura todas estas variables en Vercel antes del primer deploy
